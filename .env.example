# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM model for transcript parsing via OpenRouter
# Cheap options: deepseek/deepseek-chat, deepseek/deepseek-v3
# Default: deepseek/deepseek-chat
# LLM_MODEL=deepseek/deepseek-chat

# Optional: Database path (default: data/annotations.db)
# DB_PATH=data/annotations.db

# Optional: Images directory (default: data/images)
# IMAGES_DIR=data/images
